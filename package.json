{
  "name": "mk1-ts",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "mk1-ts": "./src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts --help",
    "cli": "bun run src/index.ts",
    "demo:lexer": "bun run src/demo-lexer.ts",
    "demo:parser": "bun run src/demo-parser.ts",
    "test": "bun test",
    "check": "bunx tsc --noEmit",
    "build": "bun build ./src/index.ts --outdir ./dist --production"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2"
  }
}
